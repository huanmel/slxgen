@startuml FanCtrl

' Fan Mode Control — initial draft specification
'
' Written by hand to agree on topology before creating the YAML.
' Annotated with en: action blocks (custom notation; maps to en: in YAML).
' Compare with fan_ctrl_gen.puml (generated from fan_ctrl_sf.yaml) to
' verify the YAML correctly captures this intent.
'
' Hierarchy:
'   STANDBY                  — fan off; idle state
'   ACTIVE (compound)        — fan running
'     A_ENTRY (immediate)    — routes to BOOST or NORMAL on ACTIVE entry
'     BOOST                  — override mode; locks to HIGH; exits when request drops
'     NORMAL (compound)      — normal speed control
'       N_ENTRY (immediate)  — routes to AUTO or MANUAL (uses hist_auto)
'       AUTO                 — controller selects speed
'       MANUAL (history)     — user-selected speed
'         INIT (default)     — hold last speed; wait for first button press
'         LOW / MED / HIGH

[*] --> STANDBY

state STANDBY
state ACTIVE {
  [*] --> A_ENTRY
  state A_ENTRY
  state BOOST
  state NORMAL {
    [*] --> N_ENTRY
    state N_ENTRY
    state AUTO
    state MANUAL {
      [*] --> INIT
      state INIT
      state LOW
      state MED
      state HIGH
    }
  }
}

STANDBY : en:\nfan_mode=FanMode_e.STANDBY;\nfan_spd=FanSpd_e.OFF;
AUTO    : en:\nfan_mode=FanMode_e.AUTO;\nhist_auto=true;
MANUAL  : en:\nfan_mode=FanMode_e.MANUAL;\nhist_auto=false;
LOW     : en:\nfan_spd=FanSpd_e.LOW;
MED     : en:\nfan_spd=FanSpd_e.MED;
HIGH    : en:\nfan_spd=FanSpd_e.HIGH;
BOOST   : en:\nfan_mode=FanMode_e.BOOST;\nfan_spd=FanSpd_e.HIGH;

STANDBY --> ACTIVE  : after(debTout,tick) [fan_on]
ACTIVE  --> STANDBY : after(debTout,tick) [~fan_on]
A_ENTRY --> BOOST   : [boost_req]
A_ENTRY --> NORMAL  : [~boost_req]
NORMAL  --> BOOST   : after(debTout,tick) [boost_req]
BOOST   --> NORMAL  : after(debTout,tick) [~boost_req]
N_ENTRY --> AUTO    : [mode2auto || (hist_auto && ~mode2manual)]
N_ENTRY --> MANUAL  : [mode2manual || ~hist_auto]
AUTO    --> MANUAL  : after(debTout,tick) [mode2manual]
MANUAL  --> AUTO    : after(debTout,tick) [mode2auto]
INIT    --> LOW     : after(debTout,tick) [low_press]
INIT    --> MED     : after(debTout,tick) [med_press]
INIT    --> HIGH    : after(debTout,tick) [high_press]
LOW     --> MED     : after(debTout,tick) [med_press]
LOW     --> HIGH    : after(debTout,tick) [high_press]
MED     --> LOW     : after(debTout,tick) [low_press]
MED     --> HIGH    : after(debTout,tick) [high_press]
HIGH    --> LOW     : after(debTout,tick) [low_press]
HIGH    --> MED     : after(debTout,tick) [med_press]

@enduml
